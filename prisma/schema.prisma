// Prisma schema file — https://pris.ly/d/prisma-schema
//
// Getting started:
//   1. Set DATABASE_URL in .env.local (never commit it)
//   2. Define your models below
//   3. Run: pnpm prisma migrate dev --name init
//
// Notes for Prisma 7:
//   - The datasource URL lives in prisma.config.ts (not here)
//   - The PrismaClient is instantiated with an adapter in src/lib/db.ts
//   - The generated client lives in src/generated/prisma — always import via @/lib/db
//
// The singleton is in src/lib/db.ts. Always import `db` from there.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Define your models below this line.

// Chalk-editable content tables
model HeroContent {
  id          String @id @default(cuid())
  headline    String @default("De principiante a desarrollador. El camino real.")
  subtitle    String @default("Sin atajos, sin frameworks de moda. Solo fundamentos sólidos y código que funciona.")
  ctaText     String @default("Empezar ahora")
  ctaLink     String @default("#features")
  updatedAt   DateTime @updatedAt
}

model Feature {
  id          String @id @default(cuid())
  icon        String @default("Code")
  title       String @default("Fundamentos sólidos")
  description String @default("Aprende los conceptos que no cambian, independientemente del framework de turno.")
  order       Int    @default(0)
  isActive    Boolean @default(true)
  updatedAt   DateTime @updatedAt
}

model Step {
  id          String @id @default(cuid())
  number      Int    @default(1)
  title       String @default("Aprende los conceptos")
  description String @default("Domina la lógica, estructuras de datos y algoritmos.")
  order       Int    @default(0)
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id          String @id @default(cuid())
  quote       String @default("Esta comunidad me ayudó a entender que ser desarrollador es sobre resolver problemas, no memorizar sintaxis.")
  author      String @default("Alex Chen")
  role        String @default("Backend Developer")
  avatarUrl   String?
  order       Int    @default(0)
  isActive    Boolean @default(true)
  updatedAt   DateTime @updatedAt
}

model CTABanner {
  id          String @id @default(cuid())
  title       String @default("¿Listo para empezar tu camino?")
  subtitle    String @default("Únete a miles de desarrolladores que aprenden con nosotros.")
  buttonText  String @default("Unirse ahora")
  buttonLink  String @default("#")
  updatedAt   DateTime @updatedAt
}

// Notification tables (boilerplate)
model Notification {
  id          String    @id @default(cuid())
  userSub     String
  workflowKey String
  title       String
  body        String
  data        Json?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userSub, readAt])
  @@index([userSub, createdAt])
}

// Souped-owned: managed by Souped via MCP. The `souped_` prefix marks it so —
// do NOT alter its structure from the app; Souped administers the schema.
model NotificationWorkflowConfig {
  key               String   @id
  label             String
  description       String
  availableChannels String[]
  enabled           Boolean  @default(false)
  channels          String[]
  updatedAt         DateTime @updatedAt

  @@map("souped_notification_workflow_config")
}
