# Copy this file to .env.local and fill the values. Never commit .env.local.

# --- Database ---------------------------------------------------------------
# Postgres connection string. Local example:
#   postgresql://postgres:postgres@localhost:5432/souped_boilerplate?schema=public
DATABASE_URL=

# --- App --------------------------------------------------------------------
# Public URL of your deployed app (used in metadata, callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Souped auth ------------------------------------------------------------
# Flip this to "true" to activate the Souped OAuth proxy. The boilerplate ships
# with auth wired but disabled — all routes are public until you turn it on.
# See AGENTS.md → "Enabling auth" for the full activation steps.
SOUPED_AUTH_ENABLED=false

# Required when SOUPED_AUTH_ENABLED=true. Get these from the Souped dashboard
# after creating a Web App: https://souped.tools
SOUPED_URL=https://souped.tools
SOUPED_CLIENT_ID=
SOUPED_CLIENT_SECRET=
SOUPED_PROJECT_ID=
# A 32+ char random string used to encrypt the session cookie.
# Generate one with: `openssl rand -base64 32`
SOUPED_SESSION_SECRET=
